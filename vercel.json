{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "backend/src/**",
          "backend/prisma/**",
          "backend/node_modules/.prisma/**",
          "backend/node_modules/@prisma/client/**"
        ]
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/api/index.ts" },
    { "src": "/health", "dest": "backend/api/index.ts" },
    { "src": "/(.*)", "dest": "frontend/$1" }
  ]
}
